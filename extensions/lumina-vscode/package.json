{
    "name": "lumina-language",
    "displayName": "Lumina",
    "description": "Lumina (.lum) language support - syntax highlighting, snippets, and LSP",
    "version": "0.2.0",
    "publisher": "isaac-ishimwe",
    "icon": "icon.png",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "lumina",
                "aliases": [
                    "Lumina",
                    "lum"
                ],
                "extensions": [
                    ".lum"
                ],
                "icon": {
                    "light": "./icon16.svg",
                    "dark": "./icon16.svg"
                },
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "lumina",
                "scopeName": "source.lumina",
                "path": "./syntaxes/lumina.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "lumina",
                "path": "./snippets/lumina.json"
            }
        ]
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.0"
    },
    "devDependencies": {
        "@types/vscode": "^1.75.0",
        "typescript": "^5.0.0"
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    }
}